# ─────────────────────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO — VibeCoding Plantilla
# ─────────────────────────────────────────────────────────────────────────────
# Instrucciones:
#   1. Copia este archivo y renombra la copia a: .env.local
#   2. Llena cada variable con tus propios valores.
#   3. NUNCA subas .env.local a GitHub (ya esta en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────


# ── RESEND (servicio de envio de emails) ──────────────────────────────────────
#
# Donde conseguirlo:
#   1. Crea una cuenta gratuita en https://resend.com
#   2. En el menu lateral ve a "API Keys"
#   3. Haz clic en "Create API Key", dale un nombre (ej. "vibecoding")
#   4. Copia la clave que empieza con "re_..." y pegala abajo
#
# Plan gratuito: 3,000 emails/mes, no requiere tarjeta de credito.
# Documentacion: https://resend.com/docs/introduction
#
RESEND_API_KEY=

# Email desde el que se envian los mensajes automaticos.
# En el plan gratuito de Resend puedes usar: onboarding@resend.dev
# Si tienes un dominio propio verificado en Resend, usa: hola@tudominio.com
# Documentacion para dominios: https://resend.com/docs/dashboard/domains/introduction
#
RESEND_FROM_EMAIL=onboarding@resend.dev


# ── PANEL DE ADMINISTRACION ──────────────────────────────────────────────────
#
# Contrasena para entrar al panel en /admin
# Pon cualquier contrasena que quieras. Ejemplo: MiClave2024!
# Sin esto configurado, la pagina /admin mostrara instrucciones de como activarla.
#
ADMIN_PASSWORD=


# ── PAYPAL (pagos en linea) ───────────────────────────────────────────────────
#
# Solo necesario si usas la integracion avanzada con PayPal Checkout SDK.
# Para el boton basico de PayPal.me NO necesitas este valor,
# solo configura payment.paypalMeUsername en src/config/site.js.
#
# Como obtener el Client ID:
#   1. Ve a https://developer.paypal.com/dashboard/applications
#   2. Inicia sesion con tu cuenta de PayPal
#   3. Haz clic en "Create App", dale un nombre y selecciona "Merchant"
#   4. Copia el "Client ID" (el de Sandbox para pruebas, el de Live para produccion)
#
# Documentacion: https://developer.paypal.com/sdk/js/
#
NEXT_PUBLIC_PAYPAL_CLIENT_ID=


# ── GOOGLE SHEETS (base de datos de leads) ────────────────────────────────────
#
# Necesitas crear una "Service Account" en Google Cloud. Pasos:
#   1. Ve a https://console.cloud.google.com
#   2. Crea un proyecto nuevo (o usa uno existente)
#   3. En el menu busca "APIs y servicios" > "Biblioteca"
#      Busca "Google Sheets API" y actívala
#   4. Ve a "APIs y servicios" > "Credenciales"
#   5. Haz clic en "Crear credenciales" > "Cuenta de servicio"
#   6. Dale un nombre y completa el formulario
#   7. En la lista de cuentas de servicio, haz clic en la que creaste
#   8. Ve a la pestana "Claves" > "Agregar clave" > "Crear clave nueva" > JSON
#   9. Se descargara un archivo .json con tus credenciales
#
# Documentacion: https://developers.google.com/sheets/api/quickstart/nodejs
#

# El email de la cuenta de servicio (lo encuentras en el archivo .json descargado,
# campo "client_email"). Ejemplo: mi-proyecto@mi-proyecto-123456.iam.gserviceaccount.com
#
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# La clave privada de la cuenta de servicio (campo "private_key" en el .json).
# IMPORTANTE: Copia todo el valor incluyendo -----BEGIN RSA PRIVATE KEY----- y -----END RSA PRIVATE KEY-----
# Reemplaza cada salto de linea real por los dos caracteres \n (barra invertida + n)
# Ejemplo del formato correcto:
#   GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
#
GOOGLE_PRIVATE_KEY=

# El ID de tu hoja de calculo de Google Sheets.
# Como obtenerlo:
#   1. Abre tu Google Sheet en el navegador
#   2. La URL tiene este formato:
#      https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
#   3. Copia solo la parte entre /d/ y /edit
#
# IMPORTANTE: Tambien debes compartir la hoja con tu cuenta de servicio:
#   En Google Sheets haz clic en "Compartir" y agrega el email de GOOGLE_SERVICE_ACCOUNT_EMAIL
#   con permisos de "Editor".
#
GOOGLE_SHEET_ID=
